# Network: "testnet" or "mainnet"
VITE_STELLAR_NETWORK=testnet

# Stellar Horizon API (auto-detected from VITE_STELLAR_NETWORK if not set)
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC (auto-detected from VITE_STELLAR_NETWORK if not set)
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Vault contract ID (deploy separately for each network)
VITE_PADALASPLIT_VAULT_CONTRACT_ID=

# Supabase (optional — falls back to browser local storage)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Demo recipient address (optional — prefills the demo form)
VITE_DEMO_RECIPIENT_ADDRESS=
